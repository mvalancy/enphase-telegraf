#!/usr/bin/env bash
#
# load-history — Download historical Enphase data and load into InfluxDB
#
# Usage:
#   ./bin/load-history                        # interactive (recommended)
#   ./bin/load-history --stdout               # output line protocol to stdout
#   ./bin/load-history --start 2023-01-15     # specify start date
#   ./bin/load-history --dry-run              # download only, don't write to InfluxDB
#

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Source .env if present
if [ -f "$REPO_DIR/.env" ]; then
    set -a
    source "$REPO_DIR/.env"
    set +a
fi

# Use venv
if [ -x "$REPO_DIR/venv/bin/python3" ]; then
    PYTHON="$REPO_DIR/venv/bin/python3"
else
    PYTHON="python3"
fi

export PYTHONPATH="$REPO_DIR/src${PYTHONPATH:+:$PYTHONPATH}"
exec "$PYTHON" "$REPO_DIR/src/enphase_cloud/history_cli.py" "$@"
