# Enphase Enlighten credentials (required)
ENPHASE_EMAIL=you@example.com
ENPHASE_PASSWORD=yourpassword

# Gateway serial — auto-discovered from cloud if not set
# ENPHASE_SERIAL=123456789012

# InfluxDB connection (for Telegraf output, or direct examples)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=enphase
