# InfluxDB 2.x Configuration
# Generated by valpatel-linux-tools monitoring/scripts/setup-collector.sh
#
# Binds to the Tailscale IP so the API is only reachable via the mesh.
# Initial setup (org, bucket, admin user) is done via the HTTP API
# after the service starts.

bolt-path = "/var/lib/influxdb/influxd.bolt"
engine-path = "/var/lib/influxdb/engine"
http-bind-address = "__TAILSCALE_IP__:8086"
