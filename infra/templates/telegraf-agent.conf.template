# Telegraf Agent Configuration
# Generated by valpatel-linux-tools monitoring/scripts/setup-agent.sh
#
# Collects standard system metrics and ships them to InfluxDB.
# Token is injected via environment variable (systemd drop-in),
# NOT stored in this file.

[global_tags]

[agent]
  interval = "10s"
  round_interval = true
  metric_batch_size = 1000
  metric_buffer_limit = 10000
  collection_jitter = "0s"
  flush_interval = "10s"
  flush_jitter = "0s"
  hostname = ""
  omit_hostname = false

# ── Output: InfluxDB v2 ─────────────────────────────────────
[[outputs.influxdb_v2]]
  urls = ["__INFLUXDB_URL__"]
  token = "${INFLUX_TOKEN}"
  organization = "__INFLUXDB_ORG__"
  bucket = "__INFLUXDB_BUCKET__"

# ── CPU ──────────────────────────────────────────────────────
[[inputs.cpu]]
  percpu = true
  totalcpu = true
  collect_cpu_time = false
  report_active = false
  core_tags = false

# ── Memory ───────────────────────────────────────────────────
[[inputs.mem]]

# ── Swap ─────────────────────────────────────────────────────
[[inputs.swap]]

# ── Disk usage per mount ─────────────────────────────────────
[[inputs.disk]]
  ignore_fs = ["tmpfs", "devtmpfs", "devfs", "iso9660", "overlay", "aufs", "squashfs"]

# ── Disk I/O ─────────────────────────────────────────────────
[[inputs.diskio]]

# ── Network I/O ──────────────────────────────────────────────
[[inputs.net]]

# ── System (uptime, load, n_users, n_cpus) ───────────────────
[[inputs.system]]

# ── Processes summary ────────────────────────────────────────
[[inputs.processes]]

# ── Kernel stats ─────────────────────────────────────────────
[[inputs.kernel]]

# ── Systemd service status ───────────────────────────────────
[[inputs.systemd_units]]
  timeout = "5s"
  unittype = "service"

# ── Network connection states ────────────────────────────────
[[inputs.netstat]]

# ── Linux sysctl fs stats (open files, inodes) ──────────────
[[inputs.linux_sysctl_fs]]

# ── NVIDIA GPU (uncomment on GPU hosts) ─────────────────────
# [[inputs.nvidia_smi]]
#   bin_path = "/usr/bin/nvidia-smi"

# ── Docker (uncomment on Docker hosts) ──────────────────────
# [[inputs.docker]]
#   endpoint = "unix:///var/run/docker.sock"
#   timeout = "5s"
#   perdevice = true
#   total = false

# ── Temperature sensors (uncomment if available) ─────────────
# [[inputs.temp]]
